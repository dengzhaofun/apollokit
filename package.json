{
  "name": "apollokit",
  "version": "0.1.2",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/apollokit/apollokit.git"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "screenshots": "node scripts/take-screenshots.mjs",
    "sdks:generate": "pnpm --filter=server run openapi:dump && cp apps/server/openapi.json packages/sdk-core/specs/openapi.json && pnpm --filter=@repo/sdk-core run split && pnpm --filter=@apollokit/server run generate && pnpm --filter=@apollokit/client run generate && pnpm --filter=@repo/sdk-core run inject-samples && pnpm --filter=admin run gen:api-docs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ],
    "overrides": {
      "@better-auth/utils": "0.4.0",
      "better-call": "1.3.5"
    }
  }
}
