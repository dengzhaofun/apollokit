{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "echo 'apps/server has no separate build step; wrangler bundles & deploys directly'",
    "deploy": "wrangler deploy --minify --outdir dist --upload-source-maps --var SENTRY_RELEASE:$(sentry-cli releases propose-version)",
    "postdeploy": "bash scripts/upload-sourcemaps.sh",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "dotenv -e .dev.vars --override -- drizzle-kit generate",
    "db:migrate": "dotenv -e .dev.vars --override -- drizzle-kit migrate",
    "db:push": "dotenv -e .dev.vars --override -- drizzle-kit push",
    "db:studio": "dotenv -e .dev.vars --override -- drizzle-kit studio",
    "db:check": "dotenv -e .dev.vars --override -- drizzle-kit check",
    "auth:generate": "dotenv -e .dev.vars -- better-auth generate --config ./auth.config.ts --output ./src/schema/auth.ts -y",
    "tb:build": "dotenv -e .env.local -- tinybird build",
    "tb:deploy": "dotenv -e .env.local -- tinybird deploy",
    "tb:info": "dotenv -e .env.local -- tinybird info",
    "secrets:push": "bash scripts/push-secrets.sh",
    "openapi:dump": "bash scripts/dump-openapi.sh"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.2",
    "@better-auth/core": "1.6.2",
    "@hono/mcp": "^0.2.5",
    "@hono/zod-openapi": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.1.0",
    "@openrouter/ai-sdk-provider": "^2.8.1",
    "@repo/admin-agent-ui": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.11",
    "@sentry/cloudflare": "^10.50.0",
    "@tinybirdco/sdk": "^0.0.66",
    "@upstash/redis": "^1.37.0",
    "ai": "6.0.168",
    "better-auth": "^1.6.2",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "filtrex": "^3.1.0",
    "hono": "^4.12.15",
    "json-logic-js": "^2.0.5",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@repo/eslint-config": "workspace:^",
    "@repo/typescript-config": "workspace:^",
    "@sentry/cli": "^2.58.5",
    "@types/json-logic-js": "^2.0.8",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "typescript": "5.9.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}