{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "dotenv -e .dev.vars -- drizzle-kit generate",
    "db:migrate": "dotenv -e .dev.vars -- drizzle-kit migrate",
    "db:push": "dotenv -e .dev.vars -- drizzle-kit push",
    "db:studio": "dotenv -e .dev.vars -- drizzle-kit studio",
    "auth:generate": "dotenv -e .dev.vars -- better-auth generate --config ./auth.config.ts --output ./src/schema/auth.ts -y",
    "tb:build": "dotenv -e .env.local -- tinybird build",
    "tb:deploy": "dotenv -e .env.local -- tinybird deploy",
    "tb:info": "dotenv -e .env.local -- tinybird info",
    "secrets:push": "bash scripts/push-secrets.sh"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.2",
    "@better-auth/core": "1.6.2",
    "@hono/zod-openapi": "^1.2.4",
    "@neondatabase/serverless": "^1.0.2",
    "@scalar/hono-api-reference": "^0.10.7",
    "@tinybirdco/sdk": "^0.0.66",
    "@upstash/redis": "^1.37.0",
    "better-auth": "^1.6.2",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "filtrex": "^3.1.0",
    "hono": "^4.12.12",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@repo/eslint-config": "workspace:^",
    "@repo/typescript-config": "workspace:^",
    "@types/node": "^22.15.3",
    "dotenv": "^17.4.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.4.0"
  }
}