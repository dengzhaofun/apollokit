{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "apollokit-server",
  "main": "src/worker.ts",
  "compatibility_date": "2026-04-11",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // CF Workers Builds runs `npx wrangler deploy` (没有 --minify),unminified
  // bundle ~7 MiB / gzip 1.2 MiB,V8 parse + module init 在 startup 期会
  // 撞 "Script startup exceeded CPU time limit" (code 10021)。顶层启用
  // minify 让 CF Builds 走和本地 `pnpm deploy` 相同的体积。本地 deploy
  // 仍带 `--minify` flag,无副作用。
  "minify": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "placement": { "mode": "smart" },
  // Cloudflare 版本元数据 binding。@sentry/cloudflare ≥ 10.35 会自动从
  // CF_VERSION_METADATA.id 读取 release，免去手动维护 SENTRY_RELEASE。
  "version_metadata": { "binding": "CF_VERSION_METADATA" },
  // Cron triggers — scheduled handler in src/scheduled.ts.
  // Every-minute tick keeps activity state transitions (scheduled →
  // teasing → active → settling → ended → archived) and schedule
  // triggers within ~1 minute of their `fire_at`. Leaderboard cycle
  // settlement is also throttled internally by checking whether the
  // previous cycleKey has already been snapshotted — so running every
  // minute is idempotent and cheap. For true second/millisecond
  // precision (e.g. flash sales), attach a Durable Object with
  // `storage.setAlarm(...)` per activity in a follow-up phase.
  "triggers": {
    "crons": ["* * * * *"]
  },
  // Cloudflare Queues —— 事件 fan-out 的异步通道（webhook + trigger-rule）。
  // 详见 ~/.claude/plans/trigger-polished-lemur.md。
  // queue 资源需先用 `wrangler queues create apollokit-events` 和
  // `wrangler queues create apollokit-events-dlq` 创建（每个 env 一组）。
  // EVENTS_QUEUE binding 同时是 producer（events.emit → queue.send）和
  // consumer（src/queue.ts 处理 batch）。max_batch_timeout=5s 折中保证
  // 低延迟和 batch 效率；max_retries=5 后进 DLQ，由后续 cron 兜底告警。
  "queues": {
    "producers": [
      { "queue": "apollokit-events", "binding": "EVENTS_QUEUE" }
    ],
    "consumers": [
      {
        "queue": "apollokit-events",
        "max_batch_size": 50,
        "max_batch_timeout": 5,
        "max_retries": 5,
        "dead_letter_queue": "apollokit-events-dlq"
      }
    ]
  },
  // Workaround: @better-auth/api-key imports @better-auth/core/utils/* sub-paths
  // via the wildcard export pattern ("./utils/*"), which wrangler's esbuild doesn't resolve.
  // Use relative paths so esbuild treats them as file paths, not package specifiers.
  "alias": {
    "@better-auth/core/utils/async": "./node_modules/@better-auth/core/dist/utils/async.mjs",
    "@better-auth/core/utils/id": "./node_modules/@better-auth/core/dist/utils/id.mjs",
    "@better-auth/core/utils/json": "./node_modules/@better-auth/core/dist/utils/json.mjs",
    "@better-auth/core/utils/ip": "./node_modules/@better-auth/core/dist/utils/ip.mjs",
    "@better-auth/core/utils/error-codes": "./node_modules/@better-auth/core/dist/utils/error-codes.mjs"
  },
  // Hyperdrive — TCP connection pool + edge cache in front of Neon Postgres.
  // Replaces the Neon HTTP serverless driver: `pg.Client` per request reads
  // `env.HYPERDRIVE.connectionString`, which transparently resolves to the
  // pooled origin in prod and to `localConnectionString` under `wrangler dev`.
  //
  // Setup (one-time):
  //   1. In Neon, take the **direct** (non-pooler) connection string for the
  //      target branch — Hyperdrive already does transaction-mode pooling, so
  //      stacking Neon's PgBouncer would lose session state.
  //   2. `npx wrangler hyperdrive create apollokit-prod \
  //         --connection-string="postgres://USER:PASSWORD@ep-xxx.../apollokit"`
  //   3. Paste the returned UUID into `id` below.
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "7097d0a17c784fdfa2abf21c83782744",
      // Dummy password placeholder — local pg under `trust` auth ignores it,
      // but recent `wrangler dev` / miniflare validate the URL format and
      // refuse to start without a password segment. Real prod credentials
      // live in the Hyperdrive binding stored against the worker.
      "localConnectionString": "postgres://dengzhao:dummy@localhost:5432/apollokit_dev?sslmode=disable"
    }
  ],
  // Secrets used by the worker (configured via .dev.vars in dev, `wrangler secret put` in prod):
  //   DATABASE_URL              — Postgres URL for drizzle-kit (Node CLI) and
  //                               the vitest fallback. Worker runtime reads
  //                               HYPERDRIVE instead. Use the Neon **direct**
  //                               (non-pooler) endpoint in prod.
  //   BETTER_AUTH_SECRET        — random 32+ byte string for cookie signing
  //   BETTER_AUTH_URL           — base URL the auth handler is served at
  //   UPSTASH_REDIS_REST_URL    — Upstash Redis REST endpoint (https://...upstash.io)
  //   UPSTASH_REDIS_REST_TOKEN  — Upstash Redis REST API token
  //   OPENROUTER_API_KEY        — OpenRouter API key for the AI SDK provider
  //   SENTRY_DSN                — Sentry project DSN（dzfun/apollokit-server）。
  //                               未配置时 @sentry/cloudflare 自动 no-op。
  //   GOOGLE_CLIENT_ID          — Google OAuth 2.0 Web Client ID（用于 Better Auth
  //                               socialProviders.google）。在
  //                               https://console.cloud.google.com/apis/credentials
  //                               创建,Authorized redirect URIs 必须含
  //                               https://apollokit-admin.limitless-ai.workers.dev/api/auth/callback/google
  //                               和 http://localhost:3000/api/auth/callback/google。
  //   GOOGLE_CLIENT_SECRET      — 同上,对应的 Client Secret。
  //
  // Plain vars (public config; override per-environment as needed):
  //   ADMIN_URL                 — origin of the admin SPA, used to build
  //                               invitation accept links. Dev: http://localhost:3000.
  //   INVITE_FROM_ADDRESS       — From address used by the organization
  //                               invitation email. Must be an authorized
  //                               sender under your Cloudflare Email Service
  //                               onboarded domain in production.
  //   SENTRY_ENVIRONMENT        — Sentry 环境标签，默认 production；本地
  //                               dev 无此变量时 worker.ts 兜底 development。
  //
  // Bindings:
  //   MEDIA_R2 — object store for the media library (admin asset drive).
  //   Bucket name can be overridden per-env; create it first with
  //   `wrangler r2 bucket create apollokit-media`.
  //   EMAIL — Cloudflare Email Service send binding. Used by the
  //   `sendInvitationEmail` hook in Better Auth organization plugin to
  //   deliver organization invitation emails. `remote: true` lets
  //   `wrangler dev` call the real Email Service; without it the mailer
  //   falls back to a console log (see src/lib/mailer.ts).
  "vars": {
    "APP_VERSION": "0.1.7",
    "ADMIN_URL": "https://apollokit-admin.limitless-ai.workers.dev",
    "INVITE_FROM_ADDRESS": "invites@example.com",
    "SENTRY_ENVIRONMENT": "production"
  },
  "r2_buckets": [
    { "binding": "MEDIA_R2", "bucket_name": "apollokit-media" }
  ],
  "send_email": [
    { "name": "EMAIL" }
  ],
  // 通用 KV namespace —— Better Auth 的 secondaryStorage(rateLimit + 可选
  // session 缓存)走这里,key 通过 src/auth.ts 的适配层带 "auth:" 前缀。未来
  // 其他 KV 用途(Tinybird 查询缓存 / OG 抓取 / 幂等键)用别的 prefix 复用
  // 同一个 namespace,避免 wrangler.jsonc 越来越多 binding。
  //
  // 创建命令(在主仓跑,KV namespace 是账户级,跨 worktree 共享):
  //   wrangler kv namespace create apollokit-kv
  //   wrangler kv namespace create apollokit-kv --preview
  // 把命令输出的 id / preview_id 填到下面。
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "d831a09e6e004eea9e334e2b5c4a4d2b",
      "preview_id": "74ebf75cb80347e89e1800ba23e0e19e"
    }
  ]
  // "ai":            { "binding": "AI" }
}