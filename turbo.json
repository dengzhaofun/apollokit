{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "TINYBIRD_TOKEN",
    "TINYBIRD_URL",
    "TINYBIRD_WORKSPACE_ID",
    "ADMIN_URL",
    "INVITE_FROM_ADDRESS",
    "OPENROUTER_API_KEY",
    "SENTRY_DSN",
    "SENTRY_ENVIRONMENT",
    "SENTRY_AUTH_TOKEN",
    "MODE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "inputs": ["openapi-ts.config.ts", "../sdk-core/specs/**"],
      "outputs": ["src/generated/**"]
    }
  }
}
